            <column caption='Title' datatype='string' name='[title]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1325751738511360]' derivation='User' name='[usr:Calculation_1325751738511360:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' />
            </column-instance>
            <column caption='Views' datatype='integer' name='[views]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.0o28g4z1c71lec13a7f2x0mq5dw9].[none:sentiment_label:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Neutral&quot;</bucket>
