      <table>
        <view>
          <datasources>
            <datasource caption='youtube_trending_final' name='federated.0o28g4z1c71lec13a7f2x0mq5dw9' />
          </datasources>
          <datasource-dependencies datasource='federated.0o28g4z1c71lec13a7f2x0mq5dw9'>
            <column caption='% of Total titles' datatype='real' default-format='p0%' name='[Calculation_1325751738511360]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([title]) / TOTAL(COUNTD([title]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column-instance column='[views]' derivation='Avg' name='[avg:views:qk]' pivot='key' type='quantitative' />
