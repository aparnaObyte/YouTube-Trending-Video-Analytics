    <worksheet name='Sentiment Share vs. Avg Views'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Benton Sans Book'>Sentiment Share vs. Avg Views</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='youtube_trending_final' name='federated.0o28g4z1c71lec13a7f2x0mq5dw9' />
          </datasources>
          <datasource-dependencies datasource='federated.0o28g4z1c71lec13a7f2x0mq5dw9'>
            <column caption='% of Total titles' datatype='real' default-format='p0%' name='[Calculation_1325751738511360]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([title]) / TOTAL(COUNTD([title]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column-instance column='[views]' derivation='Avg' name='[avg:views:qk]' pivot='key' type='quantitative' />
            <column-instance column='[sentiment_label]' derivation='None' name='[none:sentiment_label:nk]' pivot='key' type='nominal' />
            <column caption='Sentiment ' datatype='string' name='[sentiment_label]' role='dimension' type='nominal' />
            <column caption='Title' datatype='string' name='[title]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1325751738511360]' derivation='User' name='[usr:Calculation_1325751738511360:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Columns' />
            </column-instance>
            <column caption='Views' datatype='integer' name='[views]' role='measure' type='quantitative' />
          </datasource-dependencies>
          <manual-sort column='[federated.0o28g4z1c71lec13a7f2x0mq5dw9].[none:sentiment_label:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Neutral&quot;</bucket>
              <bucket>&quot;Positive&quot;</bucket>
              <bucket>&quot;Negative&quot;</bucket>
              <bucket>%all%</bucket>
            </dictionary>
          </manual-sort>
          <aggregation value='true' />
