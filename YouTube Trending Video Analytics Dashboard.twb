          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#1f2a40' fontname='Benton Sans Book' fontsize='18' underline='true'>Negative-sentiment titles drive nearly 2x the average views of neutral content, despite making up only 15% of trending videos.</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='33429' id='31' type-v2='text' w='23636' x='74026' y='63000'>
