        </zone>
        <zone h='6857' id='10' is-scaled='1' param='C:/Users/ELCOT/Downloads/youtube (1).png' type-v2='bitmap' w='5541' x='92208' y='2429' />
        <zone h='10429' id='11' name='Avg Views' w='19740' x='51948' y='12000'>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
