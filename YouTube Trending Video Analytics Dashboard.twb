      <aliases enabled='yes' />
      <column caption=' % Positive' datatype='real' name='[Calculation_0762250984751104]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [sentiment_label] = &quot;Positive&quot; THEN 1 ELSE 0 END) / COUNT([sentiment_label])' />
      </column>
      <column caption='% of Total titles' datatype='real' default-format='p0%' name='[Calculation_1325751738511360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([title]) / TOTAL(COUNTD([title]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='max date' datatype='date' name='[Calculation_1325751751553025]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='MAX([trending_date])' />
      </column>
      <column caption='Trending duration' datatype='datetime' name='[Calculation_1325751758598147]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [trending_date])' />
      </column>
